### Spotlight API — runnable requests (WebStorm HTTP Client)
### Start the backend first: npm start (from backend/). Run requests top-to-bottom.
### The {% ... %} scripts capture tokens and pick an UPCOMING showtime + free seats
### automatically, so the reservation flow always works regardless of seed dates.

@baseUrl = http://localhost:4000/api
@email = demo@example.com
@password = Password123

### Health check
GET http://localhost:4000/health

### Register (saves tokens for the requests below — returns 409 if already registered, then use Login)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{ "name": "Demo User", "email": "{{email}}", "password": "{{password}}" }

> {%
    if (response.body.accessToken) {
      client.global.set("accessToken", response.body.accessToken);
      client.global.set("refreshToken", response.body.refreshToken);
    }
    client.global.set("today", new Date().toISOString().slice(0, 10));
%}

### Login (use if already registered)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{ "email": "{{email}}", "password": "{{password}}" }

> {%
    client.global.set("accessToken", response.body.accessToken);
    client.global.set("refreshToken", response.body.refreshToken);
    client.global.set("today", new Date().toISOString().slice(0, 10));
%}

### Current user
GET {{baseUrl}}/auth/me
Authorization: Bearer {{accessToken}}

### Refresh tokens
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{ "refreshToken": "{{refreshToken}}" }

> {% client.global.set("accessToken", response.body.accessToken); client.global.set("refreshToken", response.body.refreshToken); %}

###############################################################
# Catalog (public)
###############################################################

### All theatres
GET {{baseUrl}}/theatres

### Search theatres by name or location
GET {{baseUrl}}/theatres?q=Αθήνα

### Theatre details (with its shows)
GET {{baseUrl}}/theatres/1

### All shows
GET {{baseUrl}}/shows

### Filter shows by theatre + date (today)
GET {{baseUrl}}/shows?theatreId=1&date={{today}}

### Show details
GET {{baseUrl}}/shows/1

### Showtimes for a show
GET {{baseUrl}}/showtimes?showId=1

### All upcoming showtimes — picks the next one for the reservation flow below
GET {{baseUrl}}/showtimes

> {%
    var list = response.body;
    var future = [];
    for (var i = 0; i < list.length; i++) {
      if (new Date(list[i].startsAt).getTime() > Date.now()) future.push(list[i]);
    }
    future.sort(function (a, b) { return new Date(a.startsAt) - new Date(b.startsAt); });
    client.assert(future.length > 0, "No upcoming showtimes — reload the seed data (docker compose down -v && docker compose up -d)");
    client.global.set("showtimeId", String(future[0].id));
%}

### Showtime details (with category prices)
GET {{baseUrl}}/showtimes/{{showtimeId}}

### Seat map — picks 2 free seats to book and 2 different ones for the modify step
GET {{baseUrl}}/showtimes/{{showtimeId}}/seats

> {%
    var seats = response.body;
    var free = [];
    for (var i = 0; i < seats.length; i++) {
      if (!seats[i].taken) free.push(seats[i].seatId);
    }
    client.assert(free.length >= 4, "Not enough free seats for the demo flow");
    client.global.set("seatIds", "[" + free[0] + ", " + free[1] + "]");
    client.global.set("modifySeatIds", "[" + free[2] + ", " + free[3] + "]");
%}

###############################################################
# Reservations (require auth)
###############################################################

### Create a reservation (showtime & seats were picked automatically above)
POST {{baseUrl}}/reservations
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{ "showtimeId": {{showtimeId}}, "seatIds": {{seatIds}} }

> {% client.global.set("reservationId", String(response.body.id)); %}

### My reservations
GET {{baseUrl}}/user/reservations
Authorization: Bearer {{accessToken}}

### Reservation details
GET {{baseUrl}}/reservations/{{reservationId}}
Authorization: Bearer {{accessToken}}

### Modify reservation seats
PATCH {{baseUrl}}/reservations/{{reservationId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{ "seatIds": {{modifySeatIds}} }

### Conflict demo — booking the same seats again must fail with 409
POST {{baseUrl}}/reservations
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{ "showtimeId": {{showtimeId}}, "seatIds": {{modifySeatIds}} }

### Cancel reservation (frees the seats)
DELETE {{baseUrl}}/reservations/{{reservationId}}
Authorization: Bearer {{accessToken}}

### Logout (revokes the refresh token)
POST {{baseUrl}}/auth/logout
Content-Type: application/json

{ "refreshToken": "{{refreshToken}}" }
