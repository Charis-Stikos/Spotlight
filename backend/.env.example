# ---- Server ----
PORT=4000
NODE_ENV=development

# ---- Database (must match database/docker-compose.yml) ----
# 127.0.0.1 (not "localhost") forces IPv4 and avoids mysql2 ::1 resolution issues.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=spotlight
DB_PASSWORD=spotlightpass
DB_NAME=spotlight
DB_CONNECTION_LIMIT=10

# ---- JWT ----
# CHANGE THESE before any non-local use.
JWT_ACCESS_SECRET=dev-access-secret-change-me-0a1b2c3d
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-9z8y7x6w
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- CORS ----
# "*" reflects any origin (fine for Expo development).
CORS_ORIGIN=*
